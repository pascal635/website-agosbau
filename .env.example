# Visual-Tooling — Werte hier eintragen, dann Datei als .env kopieren.
# .env ist gitignored. Diese .env.example NICHT mit echten Werten füllen.

# Google AI Studio Key für scripts/generate-image.mjs (Stills via Gemini Imagen).
# Modell: imagen-4.0-generate-001
GEMINI_API_KEY=

# Optional: anderes Imagen-Modell überschreiben (Default: imagen-4.0-generate-001)
# GEMINI_IMAGE_MODEL=

# Higgsfield (Video/Cinematic/Audio/3D) läuft via MCP-Server (.mcp.json) per OAuth.
# Kein Token hier nötig — Auth erfolgt beim ersten MCP-Connect.
