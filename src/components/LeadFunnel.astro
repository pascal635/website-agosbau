---
import { site } from "../data/site";
interface Props { variant?: "bad" | "fliesen"; id?: string; }
const { variant = "bad", id = "angebot" } = Astro.props;

const configs = {
  bad: {
    label: "Badsanierung",
    steps: [
      { key: "art", q: "Worum geht es?", opts: ["Komplette Badsanierung", "Teilsanierung / Modernisierung", "Barrierefreies Bad", "Nur Fliesen erneuern"] },
      { key: "groesse", q: "Wie groß ist Ihr Bad ungefähr?", opts: ["bis 6 m²", "6–10 m²", "über 10 m²", "weiß ich nicht"] },
      { key: "zeitpunkt", q: "Wann möchten Sie starten?", opts: ["So schnell wie möglich", "In 1–3 Monaten", "In 3–6 Monaten", "Erst mal Orientierung"] },
      { key: "stand", q: "Aktueller Stand?", opts: ["Bestehendes Bad sanieren", "Neubau / Rohbau", "Mehrere Bäder / Objekt"] },
    ],
  },
  fliesen: {
    label: "Fliesenarbeiten",
    steps: [
      { key: "was", q: "Was soll gefliest werden?", opts: ["Bad", "Wohnraum", "Küche", "Außenbereich / Terrasse / Pool", "Gewerbe"] },
      { key: "arbeiten", q: "Welche Arbeiten?", opts: ["Komplett neu verlegen", "Alte Fliesen erneuern", "Einzelne Fliesen / Reparatur", "Großformat / XXL-Platten"] },
      { key: "flaeche", q: "Ungefähre Fläche?", opts: ["bis 10 m²", "10–30 m²", "über 30 m²", "weiß ich nicht"] },
      { key: "zeitpunkt", q: "Wann soll es losgehen?", opts: ["So schnell wie möglich", "In 1–3 Monaten", "Flexibel"] },
    ],
  },
} as const;

const cfg = configs[variant];
const totalSteps = cfg.steps.length + 1; // + Kontakt-Schritt
---
<section class="funnel section" id={id} data-variant={variant} data-total={totalSteps}>
  <div class="wrap funnel__inner">
    <span class="eyebrow">Kostenloses Angebot</span>
    <h2 class="funnel__h">In 1 Minute zu Ihrem kostenlosen Angebot</h2>
    <p class="funnel__sub">Beantworten Sie kurz ein paar Fragen – André meldet sich persönlich, meist am selben Werktag.</p>

    <div class="funnel__card">
      <div class="funnel__progress"><div class="funnel__bar" style="width:0%"></div></div>
      <div class="funnel__progress-label mono">Schritt <span class="funnel__cur">1</span> von {totalSteps}</div>

      <form class="funnel__form" novalidate>
        <!-- Web3Forms: liefert die Anfrage per E-Mail an info@agosbau.de -->
        <input type="hidden" name="access_key" value="WEB3FORMS_ACCESS_KEY_HIER_EINTRAGEN" />
        <input type="hidden" name="subject" value={`Neue Anfrage über agosbau.de – ${cfg.label}`} />
        <input type="hidden" name="from_name" value="agosbau.de Lead-Funnel" />
        <input type="checkbox" name="botcheck" class="funnel__hp" tabindex="-1" autocomplete="off" />

        {cfg.steps.map((step, i) => (
          <fieldset class="funnel__step" data-step={i} hidden={i !== 0 ? true : undefined}>
            <legend>{step.q}</legend>
            <div class="funnel__opts">
              {step.opts.map((opt) => (
                <label class="funnel__opt">
                  <input type="radio" name={step.key} value={opt} required />
                  <span>{opt}</span>
                </label>
              ))}
            </div>
          </fieldset>
        ))}

        <fieldset class="funnel__step" data-step={cfg.steps.length} hidden>
          <legend>Ihr kostenloses Angebot</legend>
          <div class="funnel__fields">
            <label>Name<input type="text" name="name" required autocomplete="name" /></label>
            <label>Telefonnummer (für den Rückruf)<input type="tel" name="telefon" required autocomplete="tel" /></label>
            <label>Ort / PLZ<input type="text" name="ort" required autocomplete="postal-code" /></label>
            <label>E-Mail (optional)<input type="email" name="email" autocomplete="email" /></label>
            <label>Nachricht (optional)<textarea name="nachricht" rows="3"></textarea></label>
            <label class="funnel__consent">
              <input type="checkbox" name="consent" required />
              <span>Ich bin mit der Kontaktaufnahme einverstanden. <a href="/datenschutz/">Datenschutz</a></span>
            </label>
          </div>
          <p class="funnel__re">{site.reassurance}</p>
        </fieldset>

        <div class="funnel__nav">
          <button type="button" class="btn btn--ghost funnel__back" hidden>← Zurück</button>
          <button type="submit" class="btn btn--primary funnel__submit" data-track="lead" data-lead="formular">Angebot anfragen →</button>
        </div>
      </form>

      <div class="funnel__done" hidden>
        <h3>Danke – wir haben Ihre Anfrage.</h3>
        <p>André meldet sich persönlich, in der Regel am selben Werktag. Kein Callcenter, kein Verkaufsdruck.</p>
        <p class="funnel__done-contact">
          Es eilt? <a href={site.phoneHref} data-track="lead" data-lead="anruf">{site.phone}</a>
          · <a href={site.whatsappHref} data-track="lead" data-lead="whatsapp">WhatsApp</a>
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .funnel__inner { max-width: 720px; }
  .funnel__h { margin-block: var(--space-3) var(--space-2); }
  .funnel__sub { color: var(--color-fg-muted); margin-bottom: var(--space-8); }
  .funnel__card { background: var(--color-bg-card); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: var(--space-8); box-shadow: var(--shadow-sm); }
  .funnel__progress { height: 6px; background: var(--color-offwhite); border-radius: var(--radius-full); overflow: hidden; }
  .funnel__bar { height: 100%; background: var(--color-copper); transition: width .3s ease; }
  .funnel__progress-label { font-size: 0.7rem; color: var(--color-mittelgrau); margin-block: var(--space-3) var(--space-6); letter-spacing: 0.08em; text-transform: uppercase; }
  .funnel__step { border: none; }
  .funnel__step legend { font-family: var(--font-sans); font-weight: 600; font-size: 1.3rem; color: var(--color-anthrazit); margin-bottom: var(--space-6); }
  .funnel__opts { display: grid; gap: var(--space-3); }
  .funnel__opt { display: flex; align-items: center; gap: var(--space-3); padding: var(--space-4); border: 1px solid var(--color-border); border-radius: var(--radius-sm); cursor: pointer; transition: border-color .15s, background .15s; }
  .funnel__opt:hover { border-color: var(--color-copper); }
  .funnel__opt:has(input:checked) { border-color: var(--color-copper); background: var(--color-copper-tint); }
  .funnel__opt input { accent-color: var(--color-copper); width: 20px; height: 20px; flex: none; }
  .funnel__fields { display: grid; gap: var(--space-4); }
  .funnel__fields label { display: grid; gap: var(--space-2); font-size: 0.85rem; font-weight: 500; color: var(--color-fg); }
  .funnel__fields input, .funnel__fields textarea { font-family: var(--font-sans); font-size: 1rem; padding: 0.75rem 1rem; border: 1px solid var(--color-hellgrau); border-radius: var(--radius-sm); background: var(--color-weiss); width: 100%; }
  .funnel__fields input:focus, .funnel__fields textarea:focus { border: 2px solid var(--color-copper); outline: none; padding: calc(0.75rem - 1px) calc(1rem - 1px); }
  .funnel__consent { display: flex !important; flex-direction: row !important; align-items: flex-start; gap: var(--space-3); font-weight: 400 !important; font-size: 0.8rem; color: var(--color-fg-muted); }
  .funnel__consent input { width: 18px; height: 18px; flex: none; margin-top: 2px; accent-color: var(--color-copper); }
  .funnel__re { margin-top: var(--space-4); font-size: 0.8rem; color: var(--color-mittelgrau); }
  .funnel__hp { position: absolute; left: -9999px; }
  .funnel__nav { display: flex; justify-content: space-between; align-items: center; gap: var(--space-4); margin-top: var(--space-8); }
  .funnel__back[hidden] { display: none; }
  .funnel__done h3 { color: var(--color-copper); margin-bottom: var(--space-3); }
  .funnel__done-contact { margin-top: var(--space-4); font-family: var(--font-mono); font-size: 0.85rem; }
  .funnel__done-contact a { border-bottom: 1px solid var(--color-copper); }
</style>

<script>
  document.querySelectorAll<HTMLElement>(".funnel").forEach((root) => {
    const total = Number(root.dataset.total);
    const steps = Array.from(root.querySelectorAll<HTMLElement>(".funnel__step"));
    const bar = root.querySelector<HTMLElement>(".funnel__bar")!;
    const cur = root.querySelector<HTMLElement>(".funnel__cur")!;
    const back = root.querySelector<HTMLButtonElement>(".funnel__back")!;
    const submit = root.querySelector<HTMLButtonElement>(".funnel__submit")!;
    const form = root.querySelector<HTMLFormElement>(".funnel__form")!;
    const done = root.querySelector<HTMLElement>(".funnel__done")!;
    const variant = root.dataset.variant || "bad";
    let i = 0;

    const track = (action: string, name: string) => {
      try { (window as any)._paq?.push(["trackEvent", "Funnel", action, name]); } catch {}
    };
    const show = (n: number) => {
      i = n;
      steps.forEach((s, idx) => (s.hidden = idx !== n));
      bar.style.width = `${Math.round(((n + 1) / total) * 100)}%`;
      cur.textContent = String(n + 1);
      back.hidden = n === 0;
      const last = n === steps.length - 1;
      submit.style.display = last ? "" : "none";
      track("step", `${variant}_step_${n + 1}`);
    };
    const advance = () => { if (i < steps.length - 1) show(i + 1); };

    // Auswahl klick → automatisch weiter
    steps.forEach((step, idx) => {
      if (idx === steps.length - 1) return; // Kontakt-Schritt nicht auto-advancen
      step.querySelectorAll<HTMLInputElement>('input[type=radio]').forEach((radio) => {
        radio.addEventListener("change", () => setTimeout(advance, 180));
      });
    });
    back.addEventListener("click", () => show(Math.max(0, i - 1)));

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      if (!form.reportValidity()) return;
      submit.disabled = true;
      submit.textContent = "Wird gesendet …";
      try {
        const data = new FormData(form);
        const res = await fetch("https://api.web3forms.com/submit", { method: "POST", body: data });
        const json = await res.json();
        if (!json.success) throw new Error(json.message || "Fehler");
        form.hidden = true;
        root.querySelector<HTMLElement>(".funnel__progress")!.hidden = true;
        root.querySelector<HTMLElement>(".funnel__progress-label")!.hidden = true;
        done.hidden = false;
        // Conversion-Tracking (Hard-Lead)
        try { (window as any)._paq?.push(["trackEvent", "Lead", "formular_absenden", `${variant}funnel`]); } catch {}
        try { (window as any).gtag?.("event", "conversion", { send_to: "AW-CONVERSION_ID/LABEL" }); } catch {}
        try { (window as any).fbq?.("track", "Lead"); } catch {}
        done.scrollIntoView({ behavior: "smooth", block: "center" });
      } catch (err) {
        submit.disabled = false;
        submit.textContent = "Erneut senden →";
        alert("Senden fehlgeschlagen. Bitte rufen Sie uns an: " + "04202 511 61 31");
      }
    });

    show(0);
  });
</script>
