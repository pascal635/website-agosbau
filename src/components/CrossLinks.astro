---
import { services } from "../data/site";
interface Props { current: string; title?: string; }
const { current, title = "Weitere Leistungen" } = Astro.props;
const others = services.filter((s) => s.href !== current);
---
<section class="section">
  <div class="wrap">
    <div class="sec-head"><span class="sec-num">Mehr von AGOS BAU</span><h2>{title}</h2></div>
    <div class="xlink__grid">
      {others.map((s) => (
        <a class="xlink" href={s.href}>
          <img src={`/images/${s.img}`} alt={s.title} width="600" height="400" loading="lazy" decoding="async" />
          <span class="xlink__title">{s.title} →</span>
        </a>
      ))}
    </div>
  </div>
</section>
<style>
  .xlink__grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-4); }
  .xlink { position: relative; border-radius: var(--radius-md); overflow: hidden; aspect-ratio: 3/2; display: block; }
  .xlink img { width: 100%; height: 100%; object-fit: cover; transition: transform .4s; }
  .xlink:hover img { transform: scale(1.05); }
  .xlink::after { content: ""; position: absolute; inset: 0; background: linear-gradient(180deg, transparent 40%, rgba(38,51,61,.78)); }
  .xlink__title { position: absolute; left: var(--space-4); bottom: var(--space-4); z-index: 2; color: var(--color-weiss); font-family: var(--font-head); font-size: 1.15rem; }
  @media (min-width: 768px) { .xlink__grid { grid-template-columns: repeat(4, 1fr); } }
</style>
